{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PIAR Digital",
  "version": "0.1.5",
  "identifier": "co.piardigital.offline",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PIAR Digital",
        "width": 1400,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "center": true,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
